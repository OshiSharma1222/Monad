# ─── Monad Testnet ────────────────────────────────────────────────────────────
# RPC endpoint for Monad testnet (chain ID 10143)
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# ─── Contract ──────────────────────────────────────────────────────────────────
# Deployed MimicWar contract address
CONTRACT_ADDRESS=0xYourContractAddressHere

# ─── Settler Wallet ────────────────────────────────────────────────────────────
# Private key of the wallet that auto-calls settleRound()
# This wallet MUST hold MON to cover gas.  Never commit the real key.
SETTLER_PRIVATE_KEY=0xYourPrivateKeyHere

# ─── WebSocket Server ──────────────────────────────────────────────────────────
# Port the WS broadcast server listens on (default: 8080)
WS_PORT=8080
